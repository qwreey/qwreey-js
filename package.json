{
  "name": "qwreey-reactutil",
  "version": "1.0.0",
  "description": "Qwreey's js utilities",
  "keywords": [
    "react",
    "typescript"
  ],
  "homepage": "https://github.com/qwreey/qwreey-js#readme",
  "bugs": {
    "url": "https://github.com/qwreey/qwreey-js/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/qwreey/qwreey-js.git"
  },
  "license": "MIT",
  "author": "me@qwreey.moe",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "check": "npm run check:tsc && npm run check:eslint && npm run check:format",
    "check:eslint": "eslint",
    "check:tsc": "npm run check:tsc --workspaces",
    "check:format": "prettier --check .",
    "fix:format": "prettier --write .",
    "prettier": "prettier"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1"
  }
}
